{
  "$defs": {
    "GraphEdge": {
      "properties": {
        "source": {
          "title": "Source",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "relationship": {
          "default": "references",
          "title": "Relationship",
          "type": "string"
        },
        "formula": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Formula"
        },
        "source_location": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceLocation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "source",
        "target"
      ],
      "title": "GraphEdge",
      "type": "object"
    },
    "GraphNode": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/GraphNodeKind"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "source_location": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceLocation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        }
      },
      "required": [
        "id",
        "kind",
        "label"
      ],
      "title": "GraphNode",
      "type": "object"
    },
    "GraphNodeKind": {
      "enum": [
        "cell",
        "range",
        "name",
        "external",
        "unsupported"
      ],
      "title": "GraphNodeKind",
      "type": "string"
    },
    "SourceLocation": {
      "description": "Original workbook location for a discovered object.",
      "properties": {
        "workbook_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Workbook Path"
        },
        "sheet_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sheet Name"
        },
        "sheet_index": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sheet Index"
        },
        "address": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Address"
        },
        "object_type": {
          "title": "Object Type",
          "type": "string"
        },
        "object_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Object Id"
        },
        "ooxml_part": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ooxml Part"
        }
      },
      "required": [
        "object_type"
      ],
      "title": "SourceLocation",
      "type": "object"
    },
    "UnsupportedFeature": {
      "properties": {
        "feature_type": {
          "title": "Feature Type",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "source_location": {
          "$ref": "#/$defs/SourceLocation"
        },
        "severity": {
          "$ref": "#/$defs/UnsupportedSeverity",
          "default": "warning"
        },
        "opaque": {
          "default": true,
          "title": "Opaque",
          "type": "boolean"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        }
      },
      "required": [
        "feature_type",
        "description",
        "source_location"
      ],
      "title": "UnsupportedFeature",
      "type": "object"
    },
    "UnsupportedSeverity": {
      "enum": [
        "info",
        "warning",
        "error"
      ],
      "title": "UnsupportedSeverity",
      "type": "string"
    }
  },
  "properties": {
    "schema_version": {
      "default": "phase1.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "artifact_type": {
      "const": "formula_graph",
      "default": "formula_graph",
      "title": "Artifact Type",
      "type": "string"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/GraphNode"
      },
      "title": "Nodes",
      "type": "array"
    },
    "edges": {
      "items": {
        "$ref": "#/$defs/GraphEdge"
      },
      "title": "Edges",
      "type": "array"
    },
    "unsupported_features": {
      "items": {
        "$ref": "#/$defs/UnsupportedFeature"
      },
      "title": "Unsupported Features",
      "type": "array"
    }
  },
  "title": "FormulaGraph",
  "type": "object"
}
