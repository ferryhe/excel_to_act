{
  "$defs": {
    "ConfirmationQuestion": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        },
        "question_type": {
          "title": "Question Type",
          "type": "string"
        },
        "source_location": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceLocation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "options": {
          "items": {
            "type": "string"
          },
          "title": "Options",
          "type": "array"
        },
        "default": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default"
        },
        "rationale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rationale"
        }
      },
      "required": [
        "id",
        "prompt",
        "question_type"
      ],
      "title": "ConfirmationQuestion",
      "type": "object"
    },
    "DecisionRecord": {
      "properties": {
        "question_id": {
          "title": "Question Id",
          "type": "string"
        },
        "decision": {
          "title": "Decision",
          "type": "string"
        },
        "reviewer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reviewer"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "source_artifact_version": {
          "default": "phase1.v1",
          "title": "Source Artifact Version",
          "type": "string"
        }
      },
      "required": [
        "question_id",
        "decision"
      ],
      "title": "DecisionRecord",
      "type": "object"
    },
    "SourceLocation": {
      "description": "Original workbook location for a discovered object.",
      "properties": {
        "workbook_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Workbook Path"
        },
        "sheet_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sheet Name"
        },
        "sheet_index": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sheet Index"
        },
        "address": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Address"
        },
        "object_type": {
          "title": "Object Type",
          "type": "string"
        },
        "object_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Object Id"
        },
        "ooxml_part": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ooxml Part"
        }
      },
      "required": [
        "object_type"
      ],
      "title": "SourceLocation",
      "type": "object"
    }
  },
  "properties": {
    "schema_version": {
      "default": "phase1.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "artifact_type": {
      "const": "confirmation_template",
      "default": "confirmation_template",
      "title": "Artifact Type",
      "type": "string"
    },
    "questions": {
      "items": {
        "$ref": "#/$defs/ConfirmationQuestion"
      },
      "title": "Questions",
      "type": "array"
    },
    "decisions": {
      "items": {
        "$ref": "#/$defs/DecisionRecord"
      },
      "title": "Decisions",
      "type": "array"
    }
  },
  "title": "ConfirmationTemplate",
  "type": "object"
}
